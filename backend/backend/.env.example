# App
APP_ENV=development
SECRET_KEY=change-me-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database — SQLite (default, no setup needed)
USE_SQLITE=true

# Database — MySQL (set USE_SQLITE=false to switch)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=vendorclear
MYSQL_PASSWORD=your-password-here
MYSQL_DB=vendorclear_ai

# Google Gemini AI (for document OCR/analysis)
GEMINI_API_KEY=your-gemini-api-key-here

# File uploads
MAX_FILE_SIZE_MB=20
UPLOAD_DIR=uploads
