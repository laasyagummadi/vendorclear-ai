# ══════════════════════════════════════════════════════════════
#  VendorClear AI — Environment Configuration
#  Copy this file to .env and fill in your values
# ══════════════════════════════════════════════════════════════

# ── Application ───────────────────────────────────────────────
APP_NAME=VendorClear AI
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# ── Database ──────────────────────────────────────────────────
# OPTION A: SQLite (zero-config, great for demos & local dev)
USE_SQLITE=true

# OPTION B: MySQL (production) — set USE_SQLITE=false and fill these in:
# USE_SQLITE=false
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=your_mysql_password
# DB_NAME=vendorclear_db

# ── JWT Auth ──────────────────────────────────────────────────
# Generate a strong key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-secret-before-going-live
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ──────────────────────────────────────────────────────
# (dev mode auto-allows all origins including file:// — no changes needed)
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=100

# ── Gemini AI (Hruthi) ────────────────────────────────────────
# Get a free key at: https://makersuite.google.com/app/apikey
# Leave empty to use the built-in regex mock (works without a key)
GEMINI_API_KEY=
